{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "A dish available in the cafe menu.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the dish" },
        "description": { "type": "string", "description": "Full description of the dish including ingredients" },
        "price": { "type": "number", "description": "Price in INR" },
        "category": { "type": "string", "description": "Category of the dish" },
        "imageUrl": { "type": "string", "description": "URL of the dish image" },
        "isAvailable": { "type": "boolean", "description": "Whether the dish is currently available" },
        "isDiscontinued": { "type": "boolean", "description": "Whether the dish has been discontinued by the owner" }
      },
      "required": ["name", "description", "price", "category", "isAvailable", "isDiscontinued"]
    }
  },
  "firestore": {
    "menuItems": {
      "schema": "MenuItem",
      "description": "Collection of all menu items."
    }
  }
}
