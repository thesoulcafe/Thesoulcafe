rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: menuItems
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - description: string (required, 1-1000 chars)
    //   - price: number (required, positive)
    //   - category: string (required, one of CATEGORIES)
    //   - isAvailable: boolean (required)
    //   - isDiscontinued: boolean (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "piush10122001@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidMenuItem(data) {
      let allowedCategories = [
        'Starters',
        'Soups',
        'Toast',
        'Lassi',
        'Hot Beverages',
        'Cornflakes/Porridge/Muesli',
        'Omelette',
        'Prantha',
        'Pasta (Italian Recipe)',
        'Pizza',
        'Indian Zaika',
        'Thali',
        'Dessert'
      ];
      return data.keys().hasAll(['name', 'description', 'price', 'category', 'isAvailable', 'isDiscontinued']) &&
             data.keys().hasOnly(['name', 'description', 'price', 'category', 'isAvailable', 'isDiscontinued']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.price is number && data.price > 0 &&
             data.category in allowedCategories &&
             data.isAvailable is bool &&
             data.isDiscontinued is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /menuItems/{itemId} {
      // Publicly readable
      allow read: if true;
      
      // Only admin can write
      allow create: if isAdmin() && isValidMenuItem(request.resource.data);
      allow update: if isAdmin() && isValidMenuItem(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
